                        <div style="background: rgba(99, 102, 241, 0.1); border-radius: 10px; height: 8px; overflow: hidden;">
                            <div id="achievementProgressBar" style="background: linear-gradient(90deg, var(--primary-color), var(--secondary-color)); height: 100%; width: 0%; border-radius: 10px; transition: width 0.5s ease;"></div>
                        </div>
                    </div>
                    <div class="achievement-grid" id="achievementGrid" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px;"></div>
                </div>

                <!-- 学习时长图表 -->
                <div class="panel">
                    <div class="panel-title">📊 学习时长统计</div>
                    <div class="study-chart-container">
