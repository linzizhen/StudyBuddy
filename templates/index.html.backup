                    </div>
                    <div class="quick-time-buttons">
                        <button class="quick-time-btn" onclick="setTimerDuration(15, this)">15 分钟</button>
                        <button class="quick-time-btn active" onclick="setTimerDuration(25, this)">25 分钟</button>
                        <button class="quick-time-btn" onclick="setTimerDuration(45, this)">45 分钟</button>
                        <button class="quick-time-btn" onclick="setTimerDuration(60, this)">60 分钟</button>
                    </div>
                    <div class="btn-group" style="margin-top: 18px;">
