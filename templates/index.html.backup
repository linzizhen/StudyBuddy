                <!-- 成就详情弹窗 -->
                <div class="modal-overlay" id="achievementModal">
                    <div class="modal" style="max-width: 500px; max-height: 80vh; overflow-y: auto;">
                        <div class="modal-header">
                            <div class="modal-title">🏆 成就列表</div>
                            <button class="modal-close" onclick="closeAchievementModal()">×</button>
                        </div>
                        <div class="modal-body" id="achievementModalBody"></div>
                    </div>
                </div>

                <!-- 到期提醒弹窗 -->
                <div class="modal-overlay" id="deadlineModal">
                    <div class="modal">
                        <div class="modal-header">
