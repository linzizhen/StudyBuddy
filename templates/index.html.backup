                            <button class="modal-close" onclick="closeModal()">×</button>
                        </div>
                        <div class="modal-body">
                            <div class="task-name" id="modalTaskName"></div>
                            <div>剩余时间：</div>
                            <div class="time-remaining" id="modalTimeRemaining"></div>
                        </div>
                        <div class="modal-footer">
                            <button class="modal-btn-secondary" onclick="closeModal()">知道了</button>
