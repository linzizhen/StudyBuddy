                                <button class="chart-tab" id="chatTabHistory" onclick="switchChatTab('history')">历史记录</button>
                            </div>
                            <button class="quick-action-btn" onclick="startNewChat()" style="padding: 6px 12px; font-size: 11px;">+ 新对话</button>
                        </div>

                        <!-- 当前对话视图 -->
